# Maintainer: Ben Kepner <u6bkep@gmail.com>
pkgname=rumble-damascene
pkgver=0.3.0
pkgrel=1
pkgdesc="Voice + text chat client in the spirit of Mumble (QUIC transport, Opus audio, Ed25519 identities)"
arch=('x86_64')
url="https://github.com/u6bkep/rumble"
license=('MIT' 'Apache-2.0')
# Runtime libraries the client links against (see `ldd` of the built binary):
#   libpulse / libpulse-simple -> libpulse, libasound -> alsa-lib,
#   libmpv.so.2 -> mpv, libxkbcommon, libvulkan -> vulkan-icd-loader,
#   libopus -> opus, libssl/libcrypto -> openssl.
depends=('libpulse' 'alsa-lib' 'mpv' 'libxkbcommon' 'vulkan-icd-loader' 'opus' 'openssl')
# A Vulkan ICD (e.g. vulkan-radeon / nvidia-utils / vulkan-intel) is needed at
# runtime for the wgpu renderer; it depends on your GPU, so it is not pinned here.
makedepends=('rust' 'cargo' 'protobuf' 'pkgconf' 'git')
options=('!lto')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
# Replace with the real digest once the v$pkgver tag is pushed:
#   cd packaging/aur && updpkgsums
sha256sums=('SKIP')

_srcdir="rumble-$pkgver"

prepare() {
    cd "$_srcdir"
    # Fetch crate + git dependencies up front so build() is the only network
    # step that matters, and so `--frozen` below can run fully offline.
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$_srcdir"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # Build only the GUI client binary (the crate also ships a `dump_bundles`
    # test/lint binary we do not want to install).
    cargo build --release --frozen -p rumble-damascene --bin rumble-damascene
}

package() {
    cd "$_srcdir"
    install -Dm0755 "target/release/rumble-damascene" \
        "$pkgdir/usr/bin/rumble-damascene"
    install -Dm0644 "packaging/linux/com.rumble.Rumble.desktop" \
        "$pkgdir/usr/share/applications/com.rumble.Rumble.desktop"
}
